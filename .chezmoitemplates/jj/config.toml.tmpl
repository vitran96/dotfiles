#:schema https://jj-vcs.github.io/jj/latest/config-schema.json

[user]
name = {{ .git_name | quote }}
email = {{ .git_email | quote }}

[revset-aliases]
HEAD = "@"

[ui]
editor = {{ .editor | quote }}
diff-editor = ":builtin"
merge-editor = "vscode"

{{ if eq .git_gpgsign "true" }}
[signing]
behaviour = "drop"
backend = "gpg"
key = {{ .git_signingkey | quote }}
{{ end }}

{{ if and (eq .chezmoi.os "windows") (eq .git_gpgsign "true") }}
[signing.backends.gpg]
program = {{ .git_gpgprogram }}
{{ end }}


[git]
{{ if eq .git_gpgsign "true" }}
sign-on-push = true
{{ end }}
auto-local-bookmark = true
track-default-bookmark-on-clone = true
push-new-bookmark = true