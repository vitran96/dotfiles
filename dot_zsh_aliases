# colored GCC warnings and errors
#export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# some more ls aliases
if command -v lsd --version >/dev/null 2>&1; then
  alias ls='lsd'
  alias l='lsd'
  alias ll='lsd -alF'
  alias la='lsd -A'
  echo "Created alias for lsd"
else
  alias ll='ls -alF'
  alias la='ls -A'
  alias l='ls -CF'
fi

if command -v dust --version >/dev/null 2>&1; then
  alias du='dust'
  echo "Created alias for dust"
fi

if [ -e /usr/bin/fdfind ]; then
  alias find='fd'
  echo "Created alias for fdfind"
fi

if [ -e /usr/bin/rg ]; then
  alias grep='rg'
  echo "Created alias for ripgrep"
fi

if [ -e /usr/bin/batcat ]; then
  alias cat='batcat'
  alias bat='batcat'
  echo "Created alias for batcat"
elif [ -e /usr/bin/bat ]; then
  alias cat='bat'
  echo "Created alias for bat"
fi

# dua might be in /usr/bin/dua -> no need for alias
if [ -e $HOME/.cargo/bin/dua ]; then
  alias dua=$HOME/.cargo/bin/dua
  echo "Created alias for dua"
fi

if [ -e $HOME/.local/share/mise/installs/node/26.5.0/bin/safe-rm ]; then
  alias rm='safe-rm'
  echo "Created alias for safe-rm"
fi

# Add an 'alert' alias for long running commands.  Use like so:
#   sleep 10; alert
alias alert='notify-send --urgency=low -i "$([ $? = 0 ] && echo terminal || echo error)" "$(history|tail -n1|sed -e '\''s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//'\'')"'

alias explorer='nautilus'

alias vim='nvim'
alias vi='nvim'
alias v='nvim'

#alias emacs-standalone='/usr/bin/emacs -nw'
#alias emacs='emacsclient -nw -a emacs-standalone'
alias emacs='/usr/bin/emacs -nw'
alias emacs-server='/usr/bin/emacs -d '
alias emacs-attach='/usr/bin/emacsclient -f '

if command -v podman --version >/dev/null 2>&1; then
  alias docker='podman'
  alias docker-compose='podman-compose'
fi

echo "Loaded .zsh_aliases"